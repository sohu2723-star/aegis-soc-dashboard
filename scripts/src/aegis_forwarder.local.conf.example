# AEGIS aegis_forwarder.py — local, machine-specific config.
#
# Copy to "aegis_forwarder.local.conf" (same folder) on the machine that runs
# this script and fill in real values there. That file is gitignored — never
# committed or pushed.
#
#   cp aegis_forwarder.local.conf.example aegis_forwarder.local.conf
#   nano aegis_forwarder.local.conf
#
# ── Hub mode (recommended) ─────────────────────────────────────────────────────
# Run ONE script on the AEGIS VM (aegis-company-admin, 10.30.30.10) — handles everything:
#   • SSHes into company-web-server  (10.10.10.10) → tails Suricata/Fail2ban/SSH/HTTP/FTP
#   • SSHes into company-customer-db (10.20.20.10) → tails Suricata/Fail2ban/SSH/MySQL
#   • SSHes into company-dns-server  (10.10.10.20) → tails BIND9 query log
#   • SSHes into company-ldap-server (10.20.20.20) → tails syslog (slapd)
#   • SSHes into pfSense (10.30.30.1) → runs easyrule/pfctl for firewall commands
#   • Runs local defense agent to cover ALL VMs from one place
#
#   python3 aegis_forwarder.py --mode hub
#
# Prerequisites (on AEGIS VM):
#   1. SSH key-based auth set up to all company VMs (no password):
#        ssh-keygen -t ed25519 -f ~/.ssh/aegis_id_rsa -N ""
#        ssh-copy-id -i ~/.ssh/aegis_id_rsa.pub sithu@10.10.10.10   # company-web-server
#        ssh-copy-id -i ~/.ssh/aegis_id_rsa.pub sithu@10.20.20.10   # company-customer-db
#        ssh-copy-id -i ~/.ssh/aegis_id_rsa.pub sithu@10.10.10.20   # company-dns-server
#        ssh-copy-id -i ~/.ssh/aegis_id_rsa.pub sithu@10.20.20.20   # company-ldap-server
#   2. SSH key for pfSense (separate key recommended):
#        ssh-keygen -t ed25519 -f ~/.ssh/pfsense_key -N ""
#        # Then in pfSense: System > User Manager > admin > Authorized SSH Keys → paste public key
#        # Enable SSH: System > Advanced > Admin Access → Enable Secure Shell
#        cat ~/.ssh/pfsense_key.pub   # copy this into pfSense
#   3. sudo without password for iptables + fail2ban-client on ALL company VMs:
#        echo "sithu ALL=(root) NOPASSWD: /sbin/iptables" | sudo tee /etc/sudoers.d/aegis-iptables
#        echo "sithu ALL=(ALL) NOPASSWD: /usr/bin/fail2ban-client" | sudo tee /etc/sudoers.d/aegis-fail2ban
#   4. pip3 install requests
# ──────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
AEGIS_URL=https://aegis-api-server-jp3b.onrender.com/api
AEGIS_KEY=
AEGIS_ADMIN_KEY=

# ── Hub mode settings ─────────────────────────────────────────────────────────
# SSH user on all company VMs
REMOTE_SSH_USER=sithu

# SSH private key path used for all company VM connections (BatchMode — no password prompt).
# Default is ~/.ssh/aegis_id_rsa; override here if you used a different key name.
REMOTE_SSH_KEY=~/.ssh/aegis_id_rsa

# ── Company VM IPs — set the actual IPs of your VMs here (no hardcoding in code) ─
# The forwarder will SSH into these IPs to tail logs.
# Leave blank or remove a line to skip that VM.
COMPANYWEB_IP=10.10.10.10
CUSTOMERDB_IP=10.20.20.10
DNSSERVER_IP=10.10.10.20
LDAPSERVER_IP=10.20.20.20

# pfSense management IP (reachable from AEGIS VM via OPT2 10.30.30.0/24)
# pfSense OPT2 interface: em3 → 10.30.30.1/24 (same segment as AEGIS VM 10.30.30.10)
PFSENSE_IP=10.30.30.1

# pfSense SSH access — forwarder SSHes into pfSense and runs easyrule/pfctl.
# No REST API package required on pfSense.
#   Key setup: ssh-keygen -t ed25519 -f ~/.ssh/pfsense_key -N ""
#   Then paste ~/.ssh/pfsense_key.pub into pfSense:
#     System > User Manager > admin > Authorized SSH Keys
PFSENSE_SSH_KEY=/root/.ssh/pfsense_key
PFSENSE_SSH_USER=admin

# pfSense Suricata EVE JSON log paths (lab topology v4 — PUBLIC + INTERNAL interfaces)
# Hub mode spawns one watcher thread per path.
# Default (if not set): /var/db/suricata/suricata_em110/eve.json + /var/db/suricata/suricata_em220/eve.json
#   em1.10 = PUBLIC  (bank-web 10.10.10.10 + DNS-Server 10.10.10.20)
#   em2.20 = INTERNAL (customer-db 10.20.20.10 + LDAP-Server 10.20.20.20)
#
# To override both paths at once (comma-separated):
# PFSENSE_SURICATA_LOGS=/var/db/suricata/suricata_em110/eve.json,/var/db/suricata/suricata_em220/eve.json
#
# To override with a single path only:
# PFSENSE_SURICATA_LOG=/var/db/suricata/suricata_em110/eve.json

# Legacy REST API vars — no longer used for execution; kept for backward compat.
# PFSENSE_API_URL=http://10.30.30.1/api/v1
# PFSENSE_API_KEY=

# Defense poll interval (seconds)
DEFENSE_POLL_SECS=5

# ── Local mode settings (--mode all, not hub) ─────────────────────────────────
# VM_NAME controls defense command execution when running locally:
#   ubuntu  → runs iptables commands locally
#   pfsense → calls the pfSense REST API (needs PFSENSE_API_KEY above)
VM_NAME=ubuntu
