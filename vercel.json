{
  "buildCommand": "pnpm --filter @workspace/aegis-dashboard run build",
  "outputDirectory": "artifacts/aegis-dashboard/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "nodejs": "20.x",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://aegis-api-server.onrender.com/api/:path*"
    }
  ]
}
